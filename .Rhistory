if(j > 1) {
prev_value = cusum_list[j-1]
}
# print(prev_value)
eq = prev_value + mu - xt - c
# print(eq)
if(eq > 0) {
result  = eq
}
if(eq >= t) {
# print(result)
summer_ends[i] = j
}
cusum_list <- c(cusum_list, result)
}
df <- data.frame(x = 1:length(temps_df[[i]]), y = cusum_list)
colnames(df) <- c("Day", "CUSUM")
ggplot(df, aes(x = Day, y = CUSUM)) + geom_point() + geom_hline(yintercept = t, color="red")
# Collect July days' temperatures
july_temps <- temps_df[1:31,]
# Take the average and standard deviation of the temperatures in July
all_mu <- vector(mode = "numeric", length = 19)
all_sd <- vector(mode = "numeric", length = 19)
for(i in 1:length(july_temps)) {
all_mu[i] <- mean(july_temps[[i]])
all_sd[i] <- sd(july_temps[[i]])
}
# Set an empty vector to be filled later
summer_ends <- vector(mode = "numeric", length = length(temps_df))
# Loop through every year
for (i in 1:length(temps_df)) {
mu = all_mu[i]
sd = all_sd[i]
# Set T and C values to 8 std devs and 0.75 std devs
t = sd * 8
c = sd * 0.75
# Create CUSUM list to track
cusum_list <- c()
# Loop through every day in the year
for (j in 1:length(temps_df[[i]])) {
# Xt is current temperature
xt = temps_df[[i]][j]
# Set previous value to 0 by default if not first day
# Otherwise set to previous day
prev_value = 0
if(j > 1) {
prev_value = cusum_list[j-1]
}
# Set result to 0 by default
result = 0
# CUSUM equation
eq = prev_value + mu - xt - c
# If the equation's result is greater than 0
# Set result to the equation's calculation
if(eq > 0) {
result  = eq
}
# Check if we passed the threshold
# Escape the loop if we do
if(eq >= t) {
summer_ends[i] = j
break
}
# Otherwise add the result to the CUSUM tracker
cusum_list <- c(cusum_list, result)
}
}
# Convert day numbers into actual dates
summer_ends_dates <- temps$DAY[summer_ends]
summer_ends_dates
library(knitr)
summers_df <- data.frame(c(1997:2015), summer_ends_dates)
colnames(summers_df) <- c("Year", "Last Day of Summer")
kable(summers_df)
